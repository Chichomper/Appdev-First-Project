<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦ Vibe Calculator"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/purple_700"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="8dp"/>

        <!-- Display card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR VIBES"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/displayEmojis"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:textSize="30sp"
                android:hint=""
                android:layout_marginBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/displayResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hint_select"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:minHeight="28dp"/>

        </LinearLayout>

        <!-- Emoji grid row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnCoffee"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="☕\ncoffee"/>

            <Button
                android:id="@+id/btnRain"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="🌧️\nrain"/>

            <Button
                android:id="@+id/btnSecret"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="🤐\nsecret"/>

            <Button
                android:id="@+id/btnDance"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="💃\ndance"/>

        </LinearLayout>

        <!-- Emoji grid row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSparkle"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="✨\nsparkle"/>

            <Button
                android:id="@+id/btnFire"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="🔥\nfire"/>

            <Button
                android:id="@+id/btnMoon"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="🌙\nnight"/>

            <Button
                android:id="@+id/btnDice"
                style="@style/VibeButton"
                android:layout_weight="1"
                android:text="🎲\nchance"/>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Clear"
                android:textColor="@color/white"
                android:backgroundTint="@color/red_700"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/btnInfo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="How it works"
                android:textColor="@color/white"
                android:backgroundTint="@color/purple_500"
                android:textSize="15sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
