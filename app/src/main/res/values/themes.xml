<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VibeCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_main</item>
    </style>

    <style name="VibeButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lines">2</item>
        <item name="android:gravity">center</item>
        <item name="strokeColor">@color/vibe_btn_border</item>
        <item name="rippleColor">@color/purple_500</item>
    </style>
</resources>
